# Maintainer: Anthony Rubick <AnthonyMichaelTDM@github.com>
pkgname=edu-vimrc-git
_pkgname=edu-vimrc
pkgver=VERSION
pkgrel=1
_destname1="/etc"
pkgdesc="vim configs"
arch=('any')
url="https://github.com/AnthonyMichaelTDM/${_pkgname}.git"
license=('GPL3')
depends=('vim')
makedepends=('git')
replaces=()
provides=("${pkgname}")
conflicts=()
options=(!strip !emptydirs)
source=(${_pkgname}::"git+${url}")
sha256sums=('SKIP')
package() {
    rm ${srcdir}/${_pkgname}/git*
    rm ${srcdir}/${_pkgname}/setup*
    cp ${srcdir}/${_pkgname}/vimrc ${pkgdir}${_destname1}
}
pkgver() {
    cd "$_pkgname"
    printf "%s.r%s" "$(date +%y.%m)" "$(git rev-list --count HEAD)"
}
